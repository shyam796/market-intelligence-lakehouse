# ── dbt ──────────────────────────────────────────
dbt/profiles.yml          # Databricks token/host
dbt/target/               # Compiled SQL and run artifacts
dbt/dbt_packages/         # Installed packages
dbt/logs/                 # dbt run logs
dbt/.user.yml             # dbt anonymous usage tracking file

# ── Python ───────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.env                      
venv/
.venv/

# ── Azure / Databricks ───────────────────────────
.databricks/              # Databricks CLI config

# ── VS Code ──────────────────────────────────────
.vscode/                  

# ── OS ───────────────────────────────────────────
.DS_Store                 # Mac metadata files
Thumbs.db                 # Windows thumbnail cache

# ── Misc ─────────────────────────────────────────
*.log
*.tmp